# Telegram
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET=your_random_secret_here

# Channel / Group
CHANNEL_ID=-1001234567890         # The channel where posts live
COMMENT_GROUP_ID=-1009876543210   # The linked discussion group (Telegram creates this automatically)
ADMIN_IDS=123456789,987654321     # Comma-separated Telegram user IDs

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/mystic_waters

# Redis
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=development
